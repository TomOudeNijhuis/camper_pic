{
    "version": "1.9",
    "configurations": [
        {
            "name": "default",
            "id": "",
            "device": "PIC16F18056",
            "imagePath": "./out/camper_pic/default.elf",
            "toolProperties": "default-tool-base",
            "tool": "Snap",
            "packs": [
                {
                    "name": "PIC16F1xxxx_DFP",
                    "vendor": "Microchip",
                    "version": "1.31.465"
                }
            ],
            "fileSet": "default",
            "toolchain": "default-XC8",
            "userVariables": "default-uservariables"
        },
        {
            "name": "Bootloaded",
            "id": "",
            "device": "PIC16F18056",
            "imageType": "application",
            "imagePath": "./out/camper_pic/Bootloaded.elf",
            "toolProperties": "Bootloaded_tool",
            "tool": "Snap",
            "packs": [
                {
                    "name": "PIC16F1xxxx_DFP",
                    "vendor": "Microchip",
                    "version": "1.31.465"
                }
            ],
            "fileSet": "Bootloaded_files",
            "toolchain": "Bootloaded_toolchain",
            "userVariables": "Bootloaded-uservariables",
            "postBuildSteps": [
                "cd My_MCC_Config/mcc && ./postBuild.sh false Bootloaded ../../out/camper_pic production"
            ]
        }
    ],
    "propertyGroups": [
        {
            "name": "Bootloaded-uservariables",
            "type": "uservariables",
            "properties": {}
        },
        {
            "name": "default-uservariables",
            "type": "uservariables",
            "properties": {}
        },
        {
            "name": "Bootloaded_toolchain",
            "type": "toolchain",
            "provider": "microchip.toolchains:xc8@3.10",
            "properties": {
                "compiler.isolate-each-function": true,
                "compiler.optimization-level": "-O1",
                "compiler.place-data-into-section": true,
                "linker.heap-size": "0",
                "linker.remove-unused-sections": true,
                "compiler++.isolate-each-function": true,
                "compiler++.optimization-level": "-O1",
                "HI-TECH-COMP.optimization-level": "-O2",
                "HI-TECH-LINK.additional-options-code-offset": "0x1000",
                "HI-TECH-LINK.code-model-rom": "default,-000-FFF",
                "HI-TECH-COMP.what-to-do": "require"
            }
        },
        {
            "name": "default-XC8",
            "type": "toolchain",
            "provider": "microchip.toolchains:xc8@3.10",
            "properties": {
                "compiler.isolate-each-function": true,
                "compiler.optimization-level": "-O1",
                "compiler.place-data-into-section": true,
                "linker.heap-size": "0",
                "linker.remove-unused-sections": true,
                "compiler++.isolate-each-function": true,
                "compiler++.optimization-level": "-O1",
                "HI-TECH-COMP.optimization-level": "-O0"
            }
        },
        {
            "name": "Bootloaded_tool",
            "type": "tool",
            "properties": {
                "memories.configurationmemory": false,
                "memories.eeprom": false,
                "memories.id": false,
                "programoptions.preserveprogram.ranges": "0-fff"
            }
        },
        {
            "name": "default-tool-base",
            "type": "tool",
            "properties": {
                "memories.configurationmemory": false,
                "memories.eeprom": false,
                "memories.id": false
            }
        }
    ],
